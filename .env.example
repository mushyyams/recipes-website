# Supabase (community recipe forks)
# Project URL: Supabase → Project Settings → API (top of page)
#   Format: https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# API key — use EITHER naming scheme (same env var names in this app):
#   New Supabase UI: "Publishable key" (sb_publishable_...) → paste below
#   Legacy UI: "anon public" key → paste below
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-publishable-or-anon-key

# Optional — New UI: "Secret key" (sb_secret_...); Legacy: "service_role"
# Required for deleting forks from /admin/forks
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Decap CMS — GitHub OAuth (for /admin publishing)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Fork moderation at /admin/forks (pick any long random string)
ADMIN_SECRET=

# Site URL (canonical links, sitemap — defaults to Vercel URL if unset)
NEXT_PUBLIC_SITE_URL=https://recipes-website-psi.vercel.app

# Google Analytics 4 measurement ID (optional — e.g. G-XXXXXXXXXX)
NEXT_PUBLIC_GA_MEASUREMENT_ID=
